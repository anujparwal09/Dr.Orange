# ============================================
# Dr. Orange AI 🍊 — Production .gitignore
# ============================================

# ---- OS & Editor ----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Environment Variables (VERY IMPORTANT) ----
.env
.env.*
backend/.env
frontend/.env.local

# ---- Dataset (VERY LARGE - NEVER PUSH) ----
Ornage disease dataset/

# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg
*.sqlite3

# ---- Virtual Environments ----
venv/
env/
.venv/

# ---- Backend ----
backend/instance/
backend/uploads/
backend/reports/
backend/__pycache__/
backend/routes/__pycache__/
backend/model/__pycache__/
backend/*.db

# ---- ML Models (TOO LARGE FOR GITHUB) ----
backend/model/*.keras
backend/model/*.h5
*.keras
*.h5

# ---- ML Training ----
ml/__pycache__/
ml/logs/
ml/training_log.csv

# ---- Frontend ----
frontend/node_modules/
frontend/.next/
frontend/out/

# ---- Logs ----
*.log

# ---- Optional / AI / Tooling ----
.antigravityignore
.gemini/

# ---- Git safety ----
*.pem
*.key